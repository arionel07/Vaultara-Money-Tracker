{
	"expo": {
		"name": "Vaultara",
		"slug": "Vaultara",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/icon.png",
		"userInterfaceStyle": "automatic",
		"ios": {
			"supportsTablet": false,
			"bundleIdentifier": "com.vaultara.moneytracker",
			"infoPlist": {
				"NSFaceIDUsageDescription": "Используется для защиты ваших финансовых данных"
			}
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/icon.png",
				"backgroundColor": "#000000"
			},
			"package": "com.vaultara.moneytracker"
		},
		"plugins": [
			"expo-router",
			"expo-font",
			"expo-sqlite",
			[
				"expo-local-authentication",
				{
					"faceIDPermission": "Используется для защиты ваших финансовых данных"
				}
			]
		],
		"scheme": "money-tracker",
		"experiments": {
			"typedRoutes": true
		}
	}
}
